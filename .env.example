# ── AI Providers ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# NoFilter GPT — unfiltered AI for chat, image, video, and realtime voice
# Obtain your key at https://nofilter.ai
NOFILTER_GPT_API_KEY=
# Optional: override the NoFilter API base URL (defaults to https://api.nofilter.ai/v1)
NOFILTER_GPT_BASE_URL=
# Optional: chat model name served by the NoFilter API (defaults to nofilter-gpt)
NOFILTER_GPT_CHAT_MODEL=
# Optional: image model name served by the NoFilter API (defaults to nofilter-image-1)
NOFILTER_GPT_IMAGE_MODEL=
# Optional: video model name served by the NoFilter API (defaults to nofilter-video-1)
NOFILTER_GPT_VIDEO_MODEL=

# ── Media Generation ─────────────────────────────────────────
# PiAPI — gateway for Flux image generation and Suno music generation
PIAPI_API_KEY=

# Leonardo AI — image generation (https://leonardo.ai)
LEONARDO_API_KEY=

# Runway — video generation
RUNWAY_API_KEY=

# ElevenLabs — voice generation
ELEVENLABS_API_KEY=

# Suno — (routed through PiAPI; set if using Suno directly)
SUNO_API_KEY=

# ── Internet & Maps ──────────────────────────────────────────
# Brave Search — real-time web search (https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=

# Google Maps — geocoding, place search, and directions (optional; falls back to OpenStreetMap)
GOOGLE_MAPS_API_KEY=

# ── Database ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth (client-side) ───────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
