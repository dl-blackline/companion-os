# ── AI Providers ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Media Generation ─────────────────────────────────────────
# PiAPI — gateway for Flux image generation and Suno music generation
PIAPI_API_KEY=

# Leonardo AI — image generation (https://leonardo.ai)
# Used for: Leonardo AI, Lucid Origin, Seedream 4.5, Nano Banana 2
LEONARDO_API_KEY=

# Runway — video generation
RUNWAY_API_KEY=

# Kling AI — video generation (https://klingai.com)
# Obtain access_key and secret_key from the Kling AI developer console
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Hailuo (MiniMax) — video generation (https://api.minimax.chat)
HAILUO_API_KEY=

# ElevenLabs — voice generation
ELEVENLABS_API_KEY=

# Suno — (routed through PiAPI; set if using Suno directly)
SUNO_API_KEY=

# ── Internet & Maps ──────────────────────────────────────────
# Brave Search — real-time web search (https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=

# Google Maps — geocoding, place search, and directions (optional; falls back to OpenStreetMap)
GOOGLE_MAPS_API_KEY=

# ── Database ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth (client-side) ───────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
